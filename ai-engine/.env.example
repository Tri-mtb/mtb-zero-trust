# AI Engine (PDP) Environment Variables
# Copy this file as .env if you need to override defaults

# Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Geo policy
ENFORCE_GEO_BLOCK=false
ALLOWED_COUNTRIES=VN

# Time and rate policy
BUSINESS_HOUR_START=6
BUSINESS_HOUR_END=20
ALERT_THRESHOLD=40
BLOCK_THRESHOLD=80
ELEVATED_RATE_THRESHOLD=10
HIGH_RATE_THRESHOLD=20

# Model thresholds
MODEL_ALERT_THRESHOLD=0.45
MODEL_BLOCK_THRESHOLD=0.7
