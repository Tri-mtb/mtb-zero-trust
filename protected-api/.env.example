# Protected API (Module A) Environment Variables
# Copy this file as .env and fill in your values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
INTERNAL_GATEWAY_SECRET=replace-with-the-same-shared-secret-as-gateway

# AI Engine callback endpoint
AI_ENGINE_URL=http://localhost:5000

# Bind to localhost by default so the service is not exposed beyond the local machine
HOST=127.0.0.1

# Server Port
PORT=4000
